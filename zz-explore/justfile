# Throwaway investigation recipes. Live here, not the root justfile, to
# keep top-level `just --list` legible. Invoked as
# `just explore <recipe>` (e.g. `just explore issue-35-mkcircus-plugin-closure`).

# Smoke-test the new crush provider against the local circus llama-server.
# Starts circus (idempotent — attaches to existing daemon), waits for the
# portfile, then execs `clown --profile crush-local`. Requires
# `just build` to have produced ./result/bin/{clown,circus}. Exits if
# circus fails to bring up llama-server (no model? port conflict?).
crush-local-smoke MODEL='':
    #!/usr/bin/env bash
    set -euo pipefail
    root=$(git rev-parse --show-toplevel)
    cd "$root"

    if [[ ! -x ./result/bin/circus || ! -x ./result/bin/clown ]]; then
        echo "FAIL: ./result/bin/{circus,clown} missing — run 'just build' first" >&2
        exit 2
    fi

    portfile="$HOME/.local/state/circus/llama-server.port"

    # When MODEL is given, stop any running daemon first — circus
    # silently ignores --model when attaching to an already-running
    # llama-server (cmd/circus/daemon.go:attachOrStart).
    if [[ -n "{{MODEL}}" ]]; then
        echo ">> circus stop (to honor --model {{MODEL}})"
        ./result/bin/circus stop || true
        echo ">> circus start --model {{MODEL}}"
        ./result/bin/circus start --model "{{MODEL}}"
    else
        echo ">> circus start"
        ./result/bin/circus start
    fi

    echo ">> waiting for portfile $portfile"
    for i in $(seq 1 60); do
        if [[ -s "$portfile" ]]; then
            break
        fi
        sleep 1
    done
    if [[ ! -s "$portfile" ]]; then
        echo "FAIL: portfile never appeared at $portfile" >&2
        ./result/bin/circus status >&2 || true
        exit 1
    fi
    echo "   port: $(cat "$portfile")"

    echo
    echo ">> launching clown --profile crush-local"
    echo "   (Ctrl-C to exit; 'just explore crush-local-stop' to kill the daemon)"
    echo
    exec ./result/bin/clown --profile crush-local

# Stop the circus daemon started by crush-local-smoke.
crush-local-stop:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "$(git rev-parse --show-toplevel)"
    ./result/bin/circus stop || echo "circus already stopped"
#
# Submodule recipes run with CWD set to this directory by default; the
# recipes below use absolute paths or `git rev-parse --show-toplevel`
# so that's harmless.

# Direct invocation of the built clown-hook-allow binary to confirm
# its output schema. No API spend; just feeds sample stdin and prints
# the JSON the binary emits.
allowtools-hook-direct:
    #!/usr/bin/env bash
    set -euo pipefail
    root=$(git rev-parse --show-toplevel)
    cd "$root"

    clown_real=$(readlink -f ./result/bin/clown)
    cc=$(nix-store --query --references "$clown_real" | grep '/nix/store/[a-z0-9]\+-clown-0' | head -1)
    cc=$(nix-store --query --references "$cc" | grep '/nix/store/[a-z0-9]\+-claude-code' | head -1)
    hook=$(jq -r '.hooks.PreToolUse[0].hooks[0].command' "$cc/etc/claude/managed-settings.json")
    echo "binary: $hook"
    echo

    echo "=== Read /nix/store/... → expect allow ==="
    echo '{"tool_name":"Read","tool_input":{"file_path":"/nix/store/abc/x"}}' | "$hook"
    echo "=== Read /etc/passwd → expect defer ==="
    echo '{"tool_name":"Read","tool_input":{"file_path":"/etc/passwd"}}' | "$hook"
    echo "=== Bash → expect defer ==="
    echo '{"tool_name":"Bash","tool_input":{"command":"ls"}}' | "$hook"

# Empirical test: which hook output form does claude-code 2.1.111
# actually honor? Builds throwaway hook scripts (exit-only, bare
# permissionDecision, nested hookSpecificOutput, defer, deny), runs
# each via --settings argv with a matcher that DOES fire the hook,
# and reports whether Read against the named path succeeded.
#
# Findings on 2026-04-29 (claude-code 2.1.111):
#   - For allow on /nix/store: A, B, C all PASS — exit 0 alone is
#     enough; bare or nested permissionDecision both work.
#   - For defer/no-opinion on /etc/passwd: ALWAYS allowed in --print
#     mode, including with no hook at all. Print mode appears to
#     auto-approve Read by default when no hook explicitly denies.
#   - The deny control test was inconclusive (API credit ran out).
#
# This recipe is kept around as documentation of the variants; not
# expected to be run routinely.
allowtools-hook-output-forms:
    #!/usr/bin/env bash
    set -euo pipefail
    root=$(git rev-parse --show-toplevel)
    cd "$root"

    target=$(readlink -f ./result/share/fish/vendor_completions.d/clown.fish)
    work=$(mktemp -d)
    trap 'rm -rf "$work"' EXIT

    # Variant A: exit 0, no output.
    cat > "$work/hook-a.sh" <<'EOF'
    #!/usr/bin/env bash
    cat >/dev/null
    exit 0
    EOF
    chmod +x "$work/hook-a.sh"

    # Variant B: bare {"permissionDecision":"allow"}.
    cat > "$work/hook-b.sh" <<'EOF'
    #!/usr/bin/env bash
    cat >/dev/null
    printf '{"permissionDecision":"allow","reason":"variant B"}\n'
    exit 0
    EOF
    chmod +x "$work/hook-b.sh"

    # Variant C: nested hookSpecificOutput.
    cat > "$work/hook-c.sh" <<'EOF'
    #!/usr/bin/env bash
    cat >/dev/null
    printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"allow","permissionDecisionReason":"variant C"}}\n'
    exit 0
    EOF
    chmod +x "$work/hook-c.sh"

    run_variant() {
        local label="$1" hook="$2"
        local settings transcript
        settings=$(jq -nc --arg cmd "$hook" '{
          hooks: { PreToolUse: [
            { matcher: "Read", hooks: [{type:"command", command:$cmd}] }
          ] }
        }')
        transcript=$(mktemp)
        ./result/bin/clown -- --settings "$settings" -p --output-format stream-json --verbose \
            "Use Read DIRECTLY (no Agent dispatch) on $target — output only the first line." \
            > "$transcript" 2>/dev/null || true
        verdict=$(jq -r '
          [inputs]
          | map(select(.type == "user")
                | .message.content[]?
                | select(.type == "tool_result"))
          | (.[0] // {}).is_error // false
          | if . then "FAIL (denied)" else "PASS" end
        ' "$transcript")
        printf "  %-35s %s\n" "$label" "$verdict"
        rm -f "$transcript"
    }

    # Variant D: bare {"permissionDecision":"defer"} — does defer
    # actually fall through to default permission flow, or does the
    # exit-0 dominate and auto-allow?
    cat > "$work/hook-d-defer.sh" <<'EOF'
    #!/usr/bin/env bash
    cat >/dev/null
    printf '{"permissionDecision":"defer"}\n'
    exit 0
    EOF
    chmod +x "$work/hook-d-defer.sh"

    # Variant E: nested hookSpecificOutput defer.
    cat > "$work/hook-e-defer.sh" <<'EOF'
    #!/usr/bin/env bash
    cat >/dev/null
    printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"defer"}}\n'
    exit 0
    EOF
    chmod +x "$work/hook-e-defer.sh"

    # For the defer cases, we need a target that would normally be
    # DENIED to distinguish "defer fell through to denial" from "defer
    # silently auto-allowed". /etc/passwd is the canonical "should
    # require explicit grant" target.
    run_variant_path() {
        local label="$1" hook="$2" path="$3"
        local settings transcript
        settings=$(jq -nc --arg cmd "$hook" '{
          hooks: { PreToolUse: [
            { matcher: "Read", hooks: [{type:"command", command:$cmd}] }
          ] }
        }')
        transcript=$(mktemp)
        ./result/bin/clown -- --settings "$settings" -p --output-format stream-json --verbose \
            "Use Read DIRECTLY (no Agent dispatch) on $path — output only the first line." \
            > "$transcript" 2>/dev/null || true
        verdict=$(jq -r '
          [inputs]
          | map(select(.type == "user")
                | .message.content[]?
                | select(.type == "tool_result"))
          | (.[0] // {}).is_error // false
          | if . then "DENIED" else "ALLOWED" end
        ' "$transcript")
        printf "  %-40s on %-15s -> %s\n" "$label" "$path" "$verdict"
        rm -f "$transcript"
    }

    echo "=== hook-output forms on /nix/store (already authorized intent) ==="
    run_variant_path "A: exit 0, no stdout"            "$work/hook-a.sh"          "$target"
    run_variant_path "B: bare permissionDecision=allow" "$work/hook-b.sh"          "$target"
    run_variant_path "C: nested perm.Decision=allow"   "$work/hook-c.sh"          "$target"

    echo
    echo "=== defer behavior on /etc/passwd (would normally be DENIED) ==="
    echo "--- baseline: NO hook, /etc/passwd ---"
    settings='{}'
    transcript=$(mktemp)
    ./result/bin/clown -- --settings "$settings" -p --output-format stream-json --verbose \
        "Use Read DIRECTLY (no Agent dispatch) on /etc/passwd — output only the first line." \
        > "$transcript" 2>/dev/null || true
    baseline=$(jq -r '[inputs]|map(select(.type=="user")|.message.content[]?|select(.type=="tool_result"))|(.[0]//{}).is_error//false|if . then "DENIED" else "ALLOWED" end' "$transcript")
    printf "  %-40s on %-15s -> %s\n" "no hook" "/etc/passwd" "$baseline"
    rm -f "$transcript"

    run_variant_path "D: bare permissionDecision=defer"   "$work/hook-d-defer.sh"  "/etc/passwd"
    run_variant_path "E: nested permissionDecision=defer" "$work/hook-e-defer.sh"  "/etc/passwd"
    run_variant_path "A: exit 0 no stdout (no opinion)"   "$work/hook-a.sh"        "/etc/passwd"

    # Variant F: explicit deny — control test. If this denies, then
    # defer != deny and print mode is genuinely auto-approving when
    # no hook says "deny".
    cat > "$work/hook-f-deny.sh" <<'EOF'
    #!/usr/bin/env bash
    cat >/dev/null
    printf '{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDecisionReason":"variant F"}}\n'
    exit 0
    EOF
    chmod +x "$work/hook-f-deny.sh"

    echo
    echo "=== control: explicit deny on /etc/passwd (with full transcript) ==="
    settings=$(jq -nc --arg cmd "$work/hook-f-deny.sh" '{
      hooks: { PreToolUse: [
        { matcher: "Read", hooks: [{type:"command", command:$cmd}] }
      ] }
    }')
    transcript_f=$(mktemp)
    ./result/bin/clown -- --settings "$settings" -p --output-format stream-json --verbose \
        "Use Read DIRECTLY (no Agent dispatch) on /etc/passwd — output only the first line." \
        > "$transcript_f" 2>/dev/null || true
    echo "--- tool_result entries ---"
    jq -c 'select(.type=="user")|.message.content[]?|select(.type=="tool_result")' "$transcript_f"
    echo "--- assistant text ---"
    jq -r 'select(.type=="assistant")|.message.content[]?|select(.type=="text")|.text' "$transcript_f"
    echo "--- final result ---"
    jq -r 'select(.type=="result")|.result' "$transcript_f"
    rm -f "$transcript_f"

# Smoke test for the /nix/store auto-allow PreToolUse hook (cmd/clown-hook-allow).
# Spawns claude via the built clown in --print mode and asks it to
# exercise Read, Glob, and Grep directly (no Agent dispatch) against
# /nix/store paths. The recipe captures the stream-json transcript
# and reports pass/fail per tool by inspecting tool_result entries
# for is_error. Requires `just build` to have produced ./result/bin/clown.
allowtools-nix-store-smoke:
    #!/usr/bin/env bash
    set -euo pipefail
    root=$(git rev-parse --show-toplevel)
    cd "$root"

    target=$(readlink -f ./result/share/fish/vendor_completions.d/clown.fish)
    if [[ ! -f "$target" ]]; then
        echo "FAIL: read target not found: $target" >&2
        exit 2
    fi
    target_dir=$(dirname "$(dirname "$(dirname "$(dirname "$target")")")")

    prompt="Use the Read tool DIRECTLY (no Agent / Task / Discover dispatch) on $target. Output only the first line verbatim, nothing else."

    transcript=$(mktemp)
    debug_log=$(mktemp)
    trap 'rm -f "$transcript" "$debug_log"' EXIT

    echo "=== smoke-test target: $target ==="
    echo "=== expected first line ==="
    head -1 "$target"
    echo
    echo "=== clown -p (capturing stream-json to $transcript, hook debug log to $debug_log) ==="
    CLOWN_HOOK_DEBUG_LOG="$debug_log" ./result/bin/clown -- -p --output-format stream-json --verbose "$prompt" \
        | tee "$transcript"

    echo
    echo "=== hook debug log ==="
    if [[ -s "$debug_log" ]]; then
        cat "$debug_log"
    else
        echo "  (empty — hook was never invoked)"
    fi

    echo
    echo "=== per-tool verdict (parsed from transcript) ==="
    # Build {tool_use_id: tool_name} map from assistant tool_use entries,
    # then for each tool_result print the tool name, is_error verdict,
    # and a short content snippet.
    jq -r '
      [inputs]
      | (map(select(.type == "assistant")
             | .message.content[]?
             | select(.type == "tool_use")
             | {key: .id, value: .name})
         | from_entries) as $names
      | map(select(.type == "user")
            | .message.content[]?
            | select(.type == "tool_result")
            | {
                name: ($names[.tool_use_id] // "<unknown>"),
                err:  (.is_error // false),
                snippet: ((.content | tostring)[0:200])
              })
      | .[]
      | "  \(.name)\t\(if .err then "FAIL (denied)" else "PASS" end)\t\(.snippet)"
    ' "$transcript"

# Repro for issue #35 (closed as misdiagnosed 2026-04-29): verify whether
# mkCircus preserves plugin store paths in the closure of
# circus.packages.default. Builds a synthetic fake-flake plugin (a
# runCommand creating share/purse-first/issue35-test-plugin/), wires it
# into mkCircus, then dumps the recursive closure and reports whether
# the plugin's store path appears.
#
# Theory (confirmed by the repro): Nix reference scanning of
# clown-plugin-meta picks up the literal /nix/store paths interpolated
# into plugin-dirs, so the plugin is a transitive runtime dep and
# survives GC as long as circus.packages.default is rooted.
issue-35-mkcircus-plugin-closure:
    #!/usr/bin/env bash
    set -euo pipefail
    root=$(git rev-parse --show-toplevel)
    out_link=$(mktemp -d /tmp/clown-issue-35-XXXXXX)/result
    trap 'rm -rf "$(dirname "$out_link")"' EXIT

    echo ">> building circus.packages.default with synthetic plugin"
    nix build --show-trace --impure --out-link "$out_link" --expr "
      let
        clown = builtins.getFlake \"path:$root\";
        system = builtins.currentSystem;
        pkgs = import clown.inputs.nixpkgs { inherit system; };
        testPlugin = pkgs.runCommand \"issue-35-test-plugin\" { } ''
          mkdir -p \$out/share/purse-first/issue35-test-plugin/.claude-plugin
          cat > \$out/share/purse-first/issue35-test-plugin/.claude-plugin/plugin.json <<EOF
          {\"name\":\"issue35-test-plugin\",\"version\":\"0.0.1\",\"description\":\"issue 35 repro\"}
          EOF
        '';
        testPluginFlake = {
          packages.\${system}.default = testPlugin;
          rev = \"issue35-test\";
        };
        circus = clown.lib.\${system}.mkCircus {
          plugins = [
            { flake = testPluginFlake; dirs = [ \"share/purse-first/issue35-test-plugin\" ]; }
          ];
        };
      in circus.packages.default
    "

    echo
    echo ">> result store path:"
    result_path=$(readlink -f "$out_link")
    echo "   $result_path"

    echo
    echo ">> recursive closure (filtered to issue-35-test-plugin entries):"
    if nix-store --query --requisites "$result_path" | grep issue-35-test-plugin; then
        echo
        echo "VERDICT: plugin store path IS in the closure of circus.packages.default."
        echo "         The bug as filed (#35) is misdiagnosed — Nix reference scanning"
        echo "         already keeps the plugin alive across GC."
    else
        echo
        echo "VERDICT: plugin store path is NOT in the closure."
        echo "         Bug #35 is real: a consumer rooting only circus.packages.default"
        echo "         would let the plugin be garbage-collected."
        exit 1
    fi

    echo
    echo ">> contents of clown-plugin-meta/plugin-dirs (for reference):"
    plugin_meta=$(nix-store --query --requisites "$result_path" | grep clown-plugin-meta | head -1)
    if [[ -n "$plugin_meta" ]]; then
        echo "   meta: $plugin_meta"
        cat "$plugin_meta/plugin-dirs"
    else
        echo "   (no clown-plugin-meta found in closure — unexpected)"
    fi

# Tent-relevant: confirm that podman --volume precedence honors the
# more-specific (child) bind even when its parent is also bind-mounted
# writable. Tent mounts $TMPDIR writable AND staged plugin dirs (which
# live under $TMPDIR via os.MkdirTemp) read-only — if podman didn't
# honor the inner mount we'd have a silent write-through hole. Uses
# docker.io/library/busybox (small, ~5 MiB pull on first run).
#
# Pass criteria:
#   - PARENT_WRITE_OK             (writable bind works as advertised)
#   - CHILD_WRITE_BLOCKED         (inner :ro bind shadows parent)
tent-mount-precedence:
    #!/usr/bin/env bash
    set -euo pipefail
    work=$(mktemp -d)
    trap 'rm -rf "$work"' EXIT

    mkdir -p "$work/parent/child"
    echo preexisting > "$work/parent/file.txt"
    echo preexisting > "$work/parent/child/file.txt"

    echo "=== running busybox with parent writable, parent/child :ro ==="
    /usr/bin/podman run --rm \
      --volume "$work/parent:$work/parent" \
      --volume "$work/parent/child:$work/parent/child:ro" \
      docker.io/library/busybox:latest \
      sh -c "
        set +e
        echo '-- parent write attempt (expect OK) --'
        touch '$work/parent/wrote_parent' && echo PARENT_WRITE_OK || echo PARENT_WRITE_FAIL
        echo '-- parent/child write attempt (expect blocked) --'
        touch '$work/parent/child/wrote_child' 2>&1 | head -1
        if [ -f '$work/parent/child/wrote_child' ]; then
            echo CHILD_WRITE_OK_UNEXPECTED
        else
            echo CHILD_WRITE_BLOCKED
        fi
        echo '-- /proc/mounts entries for test paths --'
        grep -F \"$work/parent\" /proc/mounts || true
      "
    echo
    echo "=== host-side post-state ==="
    ls -la "$work/parent" "$work/parent/child"

# Time `podman run` against the tent image *outside* clown to measure
# how much of a tent invocation's wall-clock cost is container/claude
# cold start versus clown's own work. Pairs with the cmd/clown/main.go
# downstream-process Start/Wait timing logs.
#
# Runs three measurements, ITERS times each:
#   (a) `podman run … /bin/true`     — pure container bringup
#   (b) `podman run … claude --version` — bringup + claude self-test
#   (c) `podman run … claude --help`    — bringup + claude full init (TUI-adjacent)
#
# Image ref, claude binary path, and podman binary path are extracted
# from the *built* clown binary via `strings`, so the measurements
# match what `clown --tent` would actually exec. Run after `just build`.
#
# Usage: just zz-explore/tent-cold-start
#        just zz-explore/tent-cold-start ITERS=5
tent-cold-start ITERS='3':
    #!/usr/bin/env bash
    set -euo pipefail
    root=$(git rev-parse --show-toplevel)
    cd "$root"

    if [[ ! -L ./result/bin/clown ]]; then
        echo "FAIL: ./result/bin/clown missing — run 'just build' first" >&2
        exit 2
    fi

    # The result/bin/clown wrapper execs the inner Go binary. Pluck its
    # absolute path so we can `strings` it for the burned-in build vars.
    inner=$(awk -F'"' '/^exec / { print $2 }' ./result/bin/clown)
    if [[ -z "$inner" || ! -x "$inner" ]]; then
        echo "FAIL: could not resolve inner clown binary (got: '$inner')" >&2
        exit 2
    fi

    # awk's "exit on first match" pattern avoids the `strings | grep -m1`
    # SIGPIPE-under-pipefail trap (grep closes the pipe early, strings
    # dies with 141 and pipefail surfaces it).
    syms=$(strings "$inner")
    image=$(awk '/^clown-tent:/ {print; exit}' <<<"$syms")
    claude=$(awk '/^\/nix\/store\/.*-claude-code-.*\/bin\/claude$/ {print; exit}' <<<"$syms")
    podman=$(awk '/^\/nix\/store\/.*-podman-.*\/bin\/podman$/ {print; exit}' <<<"$syms")

    if [[ -z "$image" || -z "$claude" || -z "$podman" ]]; then
        echo "FAIL: could not extract image/claude/podman path from $inner" >&2
        echo "  image=$image" >&2
        echo "  claude=$claude" >&2
        echo "  podman=$podman" >&2
        exit 2
    fi

    echo "image:  $image"
    echo "claude: $claude"
    echo "podman: $podman"
    echo "iters:  {{ITERS}}"
    echo

    # Make sure the image is loaded before we start timing; otherwise
    # the first iteration eats the `podman load` cost and skews the
    # comparison.
    if ! "$podman" image exists "$image"; then
        echo "FAIL: tent image '$image' not present locally." >&2
        echo "      Start clown --tent once to trigger the image load, then re-run." >&2
        exit 2
    fi

    # Common volume args mirror tent.BuildArgs in internal/tent/tent.go
    # well enough for the measurement to mean something. We omit the
    # ~/.claude / ~/.config/claude binds for (a) and (c) since those
    # paths aren't read by /bin/true or `claude --help`, but include
    # them for `claude --version` parity (claude reads ~/.config/claude
    # eagerly on init).
    nix_ro="--volume /nix/store:/nix/store:ro"
    home_binds="--volume $HOME/.claude:$HOME/.claude --volume $HOME/.config/claude:$HOME/.config/claude --volume $HOME/.claude.json:$HOME/.claude.json"

    measure() {
        local label=$1; shift
        echo "=== $label ==="
        for i in $(seq 1 {{ITERS}}); do
            printf "  iter %d: " "$i"
            # time -p emits real/user/sys on three lines in POSIX format
            # ("real X.XX"); we grep the real line so the output stays tidy.
            { time -p "$@" >/dev/null 2>&1; } 2>&1 | awk '/^real/ { print $2 "s" }'
        done
        echo
    }

    measure "(a) podman run … /bin/true (pure container cold start)" \
        "$podman" run --rm $nix_ro "$image" /bin/true

    measure "(b) podman run … claude --version (bringup + claude self-test)" \
        "$podman" run --rm $nix_ro $home_binds "$image" "$claude" --version

    measure "(c) podman run … claude --help (bringup + claude full init)" \
        "$podman" run --rm $nix_ro $home_binds "$image" "$claude" --help

# Snapshot what a hung `clown --tent` invocation is doing. Run this in
# a *second* terminal while the first terminal is stuck — this recipe
# does NOT touch the hung clown, it just looks at the process tree and
# kernel-level state.
#
# By default, finds the most recent log under $XDG_LOG_HOME/clown/ (or
# ~/.local/log/clown/), reads the `downstream process started pid=N`
# entry to locate the podman PID, then dumps:
#
#   - pstree -ps PID         (ancestors back to init, full names)
#   - pstree -p PID          (descendants)
#   - per-descendant /proc state:
#       - State, Threads, VmRSS from /proc/<pid>/status
#       - wchan (kernel function currently sleeping in, or "running")
#       - cmdline
#   - ss -tnp filtered to descendant pids (open TCP sockets — useful
#     for spotting hangs on api.anthropic.com or similar)
#
# Optionally pass a PID directly when the log isn't where you expect:
#   just zz-explore/tent-hang-snapshot 12345
#
# Optionally pass STRACE=N (seconds) to additionally run an N-second
# strace sample on the deepest descendant (usually claude inside the
# container). Defaults to 0 (no strace, snapshot is instant).
#   just zz-explore/tent-hang-snapshot PID=12345 STRACE=3
tent-hang-snapshot PID='' STRACE='0':
    #!/usr/bin/env bash
    set -uo pipefail   # NOT -e: we want partial info on errors
    root=$(git rev-parse --show-toplevel)
    cd "$root"

    log_dir="${XDG_LOG_HOME:-$HOME/.local/log}/clown"
    pid="{{PID}}"

    if [[ -z "$pid" ]]; then
        if [[ ! -d "$log_dir" ]]; then
            echo "FAIL: log dir $log_dir does not exist" >&2
            exit 2
        fi
        # Pick by *filename* timestamp (start time), not mtime. Long-
        # running clown sessions keep their logs open and append
        # heartbeat lines every 30s, which makes their mtime newer than
        # a short tent run that finished hours earlier. Filenames look
        # like `clown-plugin-host-20260511T201151Z-150479.log`; sort the
        # ISO-Z portion descending so the freshest *start* wins.
        latest=""
        while read -r candidate; do
            [[ -r "$candidate" ]] || continue
            # Must be a tent run (new logging) AND have reached the
            # downstream-started phase. grep -q exits on first match
            # without buffering issues.
            if grep -q 'msg="tent startup begin"' "$candidate" 2>/dev/null \
            && grep -q 'msg="downstream process started"' "$candidate" 2>/dev/null; then
                latest=$candidate
                break
            fi
        done < <(ls -1 "$log_dir"/clown-plugin-host-*.log 2>/dev/null | sort -t- -k4 -r)
        if [[ -z "$latest" ]]; then
            echo "FAIL: no recent tent log with 'downstream process started' found under $log_dir" >&2
            echo "      Either no tent run has been done since the new logging shipped," >&2
            echo "      or you're invoking an older clown without the new logging." >&2
            exit 2
        fi
        echo "log:  $latest"
        # The `downstream process started` line carries the host PID of
        # the podman process clown handed control to. Take the LAST such
        # entry (in case this log spans multiple invocations).
        pid=$(awk -F'pid=' '/downstream process started/ { split($2, a, " "); v=a[1] } END { print v }' "$latest")
        if [[ -z "$pid" ]]; then
            echo "FAIL: no 'downstream process started pid=…' entry in $latest" >&2
            echo "      Either the tent run never reached that point, or you're" >&2
            echo "      running an older clown without the new logging." >&2
            exit 2
        fi
    fi

    if [[ ! -d "/proc/$pid" ]]; then
        echo "FAIL: /proc/$pid does not exist — process already exited?" >&2
        exit 2
    fi

    echo "pid:  $pid"
    echo "time: $(date -Iseconds)"
    echo

    echo "=== /proc/$pid/cmdline ==="
    tr '\0' ' ' < "/proc/$pid/cmdline"; echo
    echo

    echo "=== ancestors (pstree -ps $pid) ==="
    pstree -ps "$pid" 2>/dev/null || echo "(pstree failed)"
    echo

    echo "=== descendants (pstree -p $pid) ==="
    pstree -p "$pid" 2>/dev/null || echo "(pstree failed)"
    echo

    # Collect all descendant pids (including $pid itself) by walking
    # /proc once. pstree's machine-readable output is messy; the
    # /proc/<pid>/task/<tid>/children file is the kernel's own answer.
    declare -a all_pids=()
    walk() {
        local p=$1
        all_pids+=("$p")
        local tasks_dir="/proc/$p/task"
        if [[ -d "$tasks_dir" ]]; then
            for t in "$tasks_dir"/*/children; do
                [[ -r "$t" ]] || continue
                for c in $(cat "$t" 2>/dev/null); do
                    walk "$c"
                done
            done
        fi
    }
    walk "$pid"

    echo "=== per-process state (${#all_pids[@]} pids) ==="
    printf '%-8s %-8s %-6s %-12s %-20s %s\n' "PID" "STATE" "THR" "RSS" "WCHAN" "CMD"
    for p in "${all_pids[@]}"; do
        [[ -d "/proc/$p" ]] || continue
        state=$(awk '/^State:/ { print $2 }' "/proc/$p/status" 2>/dev/null)
        thr=$(awk '/^Threads:/ { print $2 }' "/proc/$p/status" 2>/dev/null)
        rss=$(awk '/^VmRSS:/ { print $2 $3 }' "/proc/$p/status" 2>/dev/null)
        wchan=$(cat "/proc/$p/wchan" 2>/dev/null || echo "?")
        # cmdline can be huge — clip to 60 chars
        cmd=$(tr '\0' ' ' < "/proc/$p/cmdline" 2>/dev/null | cut -c1-60)
        printf '%-8s %-8s %-6s %-12s %-20s %s\n' "$p" "${state:-?}" "${thr:-?}" "${rss:-?}" "${wchan:-?}" "$cmd"
    done
    echo

    # Per-thread breakdown. The per-process row above only shows the
    # main thread's wchan, but Go runtimes (e.g. podman) fan out into
    # 10-20 worker threads, and the *actual* blocking thread is rarely
    # the main one. /proc/<pid>/task/<tid>/wchan exposes each thread's
    # kernel-side blocking function; comm gives its name (Go assigns
    # human-readable names to many runtime threads). State letter is
    # the same single char as /proc/<pid>/status's "State:" field.
    echo "=== per-thread state ==="
    printf '%-8s %-8s %-2s %-20s %s\n' "PID" "TID" "S" "WCHAN" "COMM"
    for p in "${all_pids[@]}"; do
        [[ -d "/proc/$p/task" ]] || continue
        for tdir in "/proc/$p/task"/*; do
            [[ -d "$tdir" ]] || continue
            tid=${tdir##*/}
            tstate=$(awk '/^State:/ { print $2 }' "$tdir/status" 2>/dev/null)
            twchan=$(cat "$tdir/wchan" 2>/dev/null || echo "?")
            tcomm=$(cat "$tdir/comm" 2>/dev/null || echo "?")
            printf '%-8s %-8s %-2s %-20s %s\n' "$p" "$tid" "${tstate:-?}" "${twchan:-?}" "${tcomm:-?}"
        done
    done
    echo

    echo "=== open TCP sockets for descendant pids ==="
    # ss -tnp prints connections with the owning pid in the last column;
    # filter to our descendants. Requires CAP_NET_ADMIN to see other
    # users' sockets, but our own podman/claude descendants run as us.
    pid_filter=$(printf '%s|' "${all_pids[@]}" | sed 's/|$//')
    ss -tnp 2>/dev/null | awk -v pids="$pid_filter" '
        NR == 1 { print; next }
        match($0, /pid=([0-9]+)/, m) {
            if (m[1] ~ "^(" pids ")$") print
        }
    '
    echo

    if [[ "{{STRACE}}" != "0" ]]; then
        deepest=${all_pids[-1]}
        echo "=== strace -f -p $deepest for {{STRACE}}s ==="
        timeout "{{STRACE}}" strace -f -p "$deepest" 2>&1 | tail -n 40 || true
        echo
    fi

# Forensic followup for a hung tent run. Pairs with tent-hang-snapshot:
# given the PID of the wedged podman process, dump three things that
# tell us whether it's blocked on a sibling podman / a stale lock /
# environment-borne nonsense:
#
#   1. `pgrep -a podman` — every podman process on the system. If
#      another one is running concurrently, the rootless lock theory
#      gets traction.
#   2. `ls -la $XDG_RUNTIME_DIR/containers/` and $XDG_RUNTIME_DIR/libpod/
#      — stale lock files / sockets, with fuser to identify holders.
#   3. /proc/<pid>/environ — sorted, with the comparison-noisy entries
#      (PATH, TERM, etc.) at the bottom so the spinclass-specific ones
#      (SPINCLASS_*, ZELLIJ*, TMUX*, XDG_RUNTIME_DIR, TMPDIR) are easy
#      to spot at the top.
#
# Read-only: this does NOT touch the hung process. Safe to run while
# the user decides whether to keep waiting or SIGINT.
#
# Usage: just zz-explore/tent-hang-followup PID
tent-hang-followup PID:
    #!/usr/bin/env bash
    set -uo pipefail
    pid="{{PID}}"

    if [[ ! -d "/proc/$pid" ]]; then
        echo "FAIL: /proc/$pid does not exist — process already exited?" >&2
        exit 2
    fi

    echo "pid:  $pid"
    echo "time: $(date -Iseconds)"
    echo

    echo "=== pgrep -a podman (every podman on the system) ==="
    pgrep -a podman || echo "(none — but /proc/$pid is a podman; pgrep filter?)"
    echo

    echo "=== pgrep -a conmon (container supervisors) ==="
    pgrep -a conmon || echo "(none — confirms no container has been spawned for this run)"
    echo

    # XDG_RUNTIME_DIR resolution: prefer the hung process's own env
    # (since spinclass may have overridden it), fall back to ours.
    xdg=$(tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null \
            | awk -F= '/^XDG_RUNTIME_DIR=/ {print $2; exit}')
    if [[ -z "$xdg" ]]; then
        xdg="${XDG_RUNTIME_DIR:-/run/user/$UID}"
        echo "note: hung pid had no XDG_RUNTIME_DIR; using $xdg"
    else
        echo "XDG_RUNTIME_DIR (from /proc/$pid/environ): $xdg"
    fi
    echo

    echo "=== ls -la $xdg/containers/ ==="
    ls -la "$xdg/containers/" 2>&1 || echo "(no $xdg/containers/)"
    echo

    echo "=== ls -la $xdg/libpod/ (newer podman lock path) ==="
    ls -la "$xdg/libpod/" 2>&1 || echo "(no $xdg/libpod/)"
    echo

    echo "=== fuser on lock files (who holds them?) ==="
    shopt -s nullglob
    for lock in "$xdg/containers/podman/"*lock* "$xdg/libpod/"*lock* "$xdg/containers/podman/"*.lock; do
        [[ -e "$lock" ]] || continue
        printf "  %s: " "$lock"
        fuser "$lock" 2>&1 | tail -1
    done
    shopt -u nullglob
    echo

    echo "=== sorted env from /proc/$pid/environ (spinclass-suspect first) ==="
    tr '\0' '\n' < "/proc/$pid/environ" 2>/dev/null \
      | awk -F= '
          BEGIN { suspect = "^(SPINCLASS|ZELLIJ|TMUX|XDG_RUNTIME_DIR|TMPDIR|CLAUDE_CODE_TMPDIR|HOME|USER|PWD|CONTAINERS_|BUILDAH_|STORAGE_|DBUS_SESSION_BUS_ADDRESS|XDG_CONFIG_HOME|XDG_DATA_HOME|XDG_STATE_HOME|XDG_CACHE_HOME|CLOWN_)" }
          { if ($1 ~ suspect) susp[++nsusp]=$0; else rest[++nrest]=$0 }
          END {
              print "  -- suspect set --"
              for (i=1; i<=nsusp; i++) print "    " susp[i]
              print ""
              print "  -- everything else (alphabetical) --"
              n = asort(rest, sorted)
              for (i=1; i<=n; i++) print "    " sorted[i]
          }
      '
    echo

# Dive into the container PID namespace from the host side. Given the
# conmon supervisor PID (find via `pgrep conmon` after tent-hang-followup),
# walk its children (the container's init + descendants) and dump:
#
#   1. conmon's own state (wchan, sockets) — confirms conmon itself is
#      not the wedged one.
#   2. The full descendant tree from conmon down, with host PIDs.
#      Inside a userns-keep-id rootless container the host sees real
#      PIDs (just under a different uid map).
#   3. Per-process state row (state letter, threads, RSS, wchan,
#      cmdline truncated) for every descendant — pinpoints whether
#      claude is parked on a syscall and which one.
#   4. Per-thread wchan for the deepest descendants — Node.js fans
#      out into 10+ worker threads and the main thread's wchan often
#      lies about where it's actually blocked.
#   5. Open file descriptors of the deepest descendant — symlinks
#      to pipes, sockets, and files show what claude is waiting on
#      without needing strace.
#   6. Optional N-second strace on the deepest descendant.
#
# Read-only: does NOT touch the hung process tree.
#
# Usage: just zz-explore/tent-hang-container-dive CONMON_PID [STRACE]
tent-hang-container-dive CONMON_PID STRACE='0':
    #!/usr/bin/env bash
    set -uo pipefail
    conmon="{{CONMON_PID}}"
    strace_secs="{{STRACE}}"

    if [[ ! -d "/proc/$conmon" ]]; then
        echo "FAIL: /proc/$conmon does not exist — conmon already exited?" >&2
        exit 2
    fi

    # Sanity-check: this should actually be conmon.
    conmon_comm=$(cat "/proc/$conmon/comm" 2>/dev/null)
    if [[ "$conmon_comm" != "conmon" ]]; then
        echo "WARN: PID $conmon comm is '$conmon_comm', not 'conmon'." >&2
        echo "      Continuing anyway, but check that you passed the right PID." >&2
    fi

    echo "conmon pid: $conmon"
    echo "time:       $(date -Iseconds)"
    echo

    echo "=== conmon /proc state ==="
    cstate=$(awk '/^State:/ { print $2 }' "/proc/$conmon/status" 2>/dev/null)
    cwchan=$(cat "/proc/$conmon/wchan" 2>/dev/null)
    cthr=$(awk '/^Threads:/ { print $2 }' "/proc/$conmon/status" 2>/dev/null)
    printf "  state=%s threads=%s wchan=%s\n" "${cstate:-?}" "${cthr:-?}" "${cwchan:-?}"
    echo

    echo "=== conmon FDs (what is it waiting on?) ==="
    ls -la "/proc/$conmon/fd/" 2>/dev/null | sed 's/^/  /' || echo "  (cannot read)"
    echo

    echo "=== descendants of conmon (the container PID tree) ==="
    pstree -p "$conmon" 2>/dev/null || echo "(pstree failed)"
    echo

    # Walk children recursively from /proc/<pid>/task/<tid>/children —
    # this is the authoritative kernel view.
    declare -a all_pids=()
    walk() {
        local p=$1
        all_pids+=("$p")
        local tasks_dir="/proc/$p/task"
        [[ -d "$tasks_dir" ]] || return
        for t in "$tasks_dir"/*/children; do
            [[ -r "$t" ]] || continue
            for c in $(cat "$t" 2>/dev/null); do
                walk "$c"
            done
        done
    }
    walk "$conmon"

    echo "=== per-process state (${#all_pids[@]} pids incl. conmon) ==="
    printf '%-8s %-8s %-6s %-12s %-20s %s\n' "PID" "STATE" "THR" "RSS" "WCHAN" "CMD"
    for p in "${all_pids[@]}"; do
        [[ -d "/proc/$p" ]] || continue
        state=$(awk '/^State:/ { print $2 }' "/proc/$p/status" 2>/dev/null)
        thr=$(awk '/^Threads:/ { print $2 }' "/proc/$p/status" 2>/dev/null)
        rss=$(awk '/^VmRSS:/ { print $2 $3 }' "/proc/$p/status" 2>/dev/null)
        wchan=$(cat "/proc/$p/wchan" 2>/dev/null || echo "?")
        cmd=$(tr '\0' ' ' < "/proc/$p/cmdline" 2>/dev/null | cut -c1-80)
        printf '%-8s %-8s %-6s %-12s %-20s %s\n' "$p" "${state:-?}" "${thr:-?}" "${rss:-?}" "${wchan:-?}" "$cmd"
    done
    echo

    # Pick the deepest descendant for per-thread + fd + strace work.
    # That's typically the actual workload (claude/node) inside the
    # container.
    if [[ ${#all_pids[@]} -gt 1 ]]; then
        deepest=${all_pids[-1]}
        echo "=== per-thread state for deepest descendant (pid=$deepest) ==="
        printf '%-8s %-2s %-20s %s\n' "TID" "S" "WCHAN" "COMM"
        if [[ -d "/proc/$deepest/task" ]]; then
            for tdir in "/proc/$deepest/task"/*; do
                [[ -d "$tdir" ]] || continue
                tid=${tdir##*/}
                tstate=$(awk '/^State:/ { print $2 }' "$tdir/status" 2>/dev/null)
                twchan=$(cat "$tdir/wchan" 2>/dev/null || echo "?")
                tcomm=$(cat "$tdir/comm" 2>/dev/null || echo "?")
                printf '%-8s %-2s %-20s %s\n' "$tid" "${tstate:-?}" "${twchan:-?}" "${tcomm:-?}"
            done
        else
            echo "  (no task dir)"
        fi
        echo

        echo "=== open FDs of deepest descendant (pid=$deepest) ==="
        ls -la "/proc/$deepest/fd/" 2>/dev/null | sed 's/^/  /' || echo "  (cannot read)"
        echo

        echo "=== /proc/$deepest/cmdline ==="
        tr '\0' ' ' < "/proc/$deepest/cmdline"; echo
        echo

        if [[ "$strace_secs" != "0" ]]; then
            echo "=== strace -f -p $deepest for ${strace_secs}s ==="
            timeout "$strace_secs" strace -f -p "$deepest" 2>&1 | tail -n 60 || true
            echo
        fi
    fi

# TTY-state forensics for a tent hang under a nested multiplexer.
# Given the claude PID inside the container (find via the dive recipe's
# "deepest descendant" line), dump termios and epoll registration so we
# can tell whether claude is in raw mode, whether ICANON is on, what
# fds the main event loop is watching, and whether anything is
# registered to wake on /dev/pts/0 reads.
#
# For each fd of claude that points at a tty/pts, runs
# `stty -a -F /proc/<pid>/fd/<n>` — this works because opening
# /proc/<pid>/fd/<n> from another process gives a fresh fd referencing
# the same kernel pty, and stty's TCGETS ioctl reads termios from any
# referent regardless of mount namespace.
#
# Also dumps `/proc/<pid>/fdinfo/<epoll-fd>` for every eventpoll fd,
# which on modern kernels lists each registered fd, the event mask
# (EPOLLIN/OUT/etc.), and the user_data pointer. Cross-reference with
# the fd list to see whether claude is even watching /dev/pts/0 for
# input.
#
# As a control, also dumps termios for the host-side parent shells
# (the zmx-managed pty) so we can compare raw/ICANON/echo state across
# the stacked pty chain.
#
# Read-only. Safe to run on a live hung process.
#
# Usage: just zz-explore/tent-hang-tty-state CLAUDE_PID
tent-hang-tty-state CLAUDE_PID:
    #!/usr/bin/env bash
    set -uo pipefail
    pid="{{CLAUDE_PID}}"

    if [[ ! -d "/proc/$pid" ]]; then
        echo "FAIL: /proc/$pid does not exist." >&2
        exit 2
    fi

    echo "claude pid: $pid"
    echo "time:       $(date -Iseconds)"
    echo

    # Resolve each fd of claude. We care about: (a) anything that points
    # at /dev/pts/* or a tty, (b) eventpoll fds (we'll dump their fdinfo
    # below), (c) the rest in summary.
    declare -A fd_targets=()
    pty_fds=()
    epoll_fds=()
    if [[ -d "/proc/$pid/fd" ]]; then
        for fd_entry in "/proc/$pid/fd"/*; do
            [[ -L "$fd_entry" ]] || continue
            n=${fd_entry##*/}
            target=$(readlink "$fd_entry" 2>/dev/null || echo "?")
            fd_targets[$n]=$target
            case "$target" in
                /dev/pts/*|/dev/tty*) pty_fds+=("$n");;
                anon_inode:\[eventpoll\]) epoll_fds+=("$n");;
            esac
        done
    fi

    echo "=== claude pty fds (${#pty_fds[@]}) ==="
    if [[ ${#pty_fds[@]} -eq 0 ]]; then
        echo "  (no pty fds — claude has no terminal!)"
    else
        for n in "${pty_fds[@]}"; do
            printf "  fd %s -> %s\n" "$n" "${fd_targets[$n]}"
        done
    fi
    echo

    echo "=== termios state per pty fd ==="
    for n in "${pty_fds[@]}"; do
        echo "-- fd $n (${fd_targets[$n]}) --"
        stty -a -F "/proc/$pid/fd/$n" 2>&1 | sed 's/^/  /' || echo "  (stty failed)"
        echo
    done

    echo "=== eventpoll fds (${#epoll_fds[@]}) ==="
    for n in "${epoll_fds[@]}"; do
        info="/proc/$pid/fdinfo/$n"
        echo "-- fd $n (eventpoll) --"
        if [[ -r "$info" ]]; then
            cat "$info" | sed 's/^/  /'
        else
            echo "  (no fdinfo)"
        fi
        echo
    done

    echo "=== full fd inventory (for cross-reference with epoll user_data) ==="
    printf "  %-4s %s\n" "FD" "TARGET"
    for n in $(printf '%s\n' "${!fd_targets[@]}" | sort -n); do
        printf "  %-4s %s\n" "$n" "${fd_targets[$n]}"
    done
    echo

    # Walk ancestors of claude up to PID 1, dumping termios for any
    # pty in the chain. The interesting comparison is between claude's
    # /dev/pts/0 (container) and the host-side pty owned by the shell /
    # clown / podman parents (zmx-managed in the failing case).
    echo "=== termios along the ancestor pty chain ==="
    ancestor="$pid"
    while [[ -n "$ancestor" && "$ancestor" != "1" ]]; do
        [[ -d "/proc/$ancestor" ]] || break
        comm=$(cat "/proc/$ancestor/comm" 2>/dev/null || echo "?")
        # Column 7 of /proc/<pid>/stat is tty_nr (controlling tty).
        tty_nr=$(awk '{print $7}' "/proc/$ancestor/stat" 2>/dev/null)
        fd0=$(readlink "/proc/$ancestor/fd/0" 2>/dev/null || echo "?")
        printf "  pid=%s comm=%s tty_nr=%s fd0=%s\n" "$ancestor" "$comm" "$tty_nr" "$fd0"
        if [[ "$fd0" == /dev/pts/* || "$fd0" == /dev/tty* ]]; then
            stty -a -F "/proc/$ancestor/fd/0" 2>&1 | sed 's/^/    /' || echo "    (stty failed)"
        fi
        ancestor=$(awk '{print $4}' "/proc/$ancestor/stat" 2>/dev/null)
    done
    echo

# Generic probe loop for FDR-0007 tent design work. Runs an arbitrary
# bash script inside the tent image using the *same* podman invocation
# shape clown --tent uses (BuildArgs in internal/tent/tent.go), then
# prints stdout/stderr.
#
# Use this to iterate on:
#   - what userns mode the tent should use (--userns=keep-id vs auto)
#   - which mounts surface what (eg. is /nix/var needed for nix? does
#     the daemon socket reach in?)
#   - which baseline binaries are present vs missing
#   - whether a given /nix/store path is accessible from inside under
#     the user's current /etc/subuid range
#
# Knobs:
#   CMD            (required) bash script to run inside the container.
#                  Newlines OK; uses bash -lc so functions/here-docs
#                  work.
#   USERNS         podman --userns flag value. Defaults to keep-id
#                  (matches tent.BuildArgs today). Set to "auto" to
#                  let podman pick a fresh subuid mapping. Set empty
#                  string to drop the flag entirely.
#   IMAGE          override the image tag. Defaults to the one in
#                  version.txt (clown-tent:$(cat version.txt)).
#   EXTRA_MOUNTS   extra '--volume' args (space-separated). Use to
#                  test additional binds beyond the tent default
#                  (eg. EXTRA_MOUNTS='--volume /nix/var:/nix/var:ro').
#   PASS_DEVSHELL  if "1", forward host PATH filtered to /nix/store
#                  /bin entries (mirrors --tent-pass-devshell).
#
# The recipe does NOT mount $HOME/.claude or $HOME/.claude.json —
# those are claude-specific and would noise up generic probes. Add
# them via EXTRA_MOUNTS if testing claude-side behavior.
#
# Usage:
#   just zz-explore/tent-probe CMD='id; ls /nix/store | head -5'
#   just zz-explore/tent-probe USERNS=auto CMD='cat /proc/self/uid_map'
#   just zz-explore/tent-probe CMD='which git; which nix; which jq'
# Dump every clown-tent image currently in the local podman store.
# Useful before running tent-probe to confirm which tag to target —
# the user may have an older tent image loaded from a prior build.
tent-images:
    #!/usr/bin/env bash
    set -euo pipefail
    /usr/bin/podman image ls --filter reference='clown-tent*'

tent-probe CMD USERNS='keep-id' IMAGE='' EXTRA_MOUNTS='' PASS_DEVSHELL='0':
    #!/usr/bin/env bash
    set -euo pipefail

    image="{{IMAGE}}"
    if [[ -z "$image" ]]; then
        root=$(git rev-parse --show-toplevel)
        ver=$(tr -d '[:space:]' < "$root/version.txt")
        image="clown-tent:$ver"
    fi

    if ! /usr/bin/podman image exists "$image"; then
        echo "FAIL: image '$image' not loaded. Run 'just build' to produce" >&2
        echo "      the tent tarball, then 'podman load -i \\" >&2
        echo "      \$(nix path-info .#tent-image)' to load it." >&2
        exit 2
    fi

    userns_args=()
    if [[ -n "{{USERNS}}" ]]; then
        userns_args+=(--userns="{{USERNS}}")
    fi

    env_args=()
    if [[ "{{PASS_DEVSHELL}}" == "1" ]]; then
        # Replicate internal/tent.FilterPathToNixStore: keep
        # /nix/store/<hash>-<name>/{bin,sbin} entries, drop the rest.
        filtered=$(printf '%s' "$PATH" | tr ':' '\n' |
            awk '/^\/nix\/store\/[^\/]+\/s?bin$/' |
            paste -sd: -)
        if [[ -n "$filtered" ]]; then
            env_args+=(--env "PATH=$filtered")
            echo "(tent-probe) PATH override active: $(echo "$filtered" | tr ':' '\n' | wc -l) entries"
        else
            echo "(tent-probe) PASS_DEVSHELL=1 but no /nix/store entries in host PATH" >&2
        fi
    fi

    # Standard tent mount shape (subset of tent.BuildArgs — skip
    # claude-specific $HOME binds, plugin-host staging, etc.).
    cwd=$(pwd)
    mount_args=(
        --volume /nix/store:/nix/store:ro
        --volume "$cwd:$cwd"
        --workdir "$cwd"
    )

    # Append EXTRA_MOUNTS verbatim (caller is responsible for the
    # full --volume <src>:<dst>[:opts] forms).
    extra_arr=()
    if [[ -n "{{EXTRA_MOUNTS}}" ]]; then
        # shellcheck disable=SC2206
        extra_arr=({{EXTRA_MOUNTS}})
    fi

    echo "=== tent-probe ==="
    echo "image:   $image"
    echo "userns:  {{USERNS}}"
    echo "cwd:     $cwd"
    if (( ${#extra_arr[@]} )); then
        echo "extras:  ${extra_arr[*]}"
    fi
    echo "===================="
    echo

    /usr/bin/podman run --rm -i \
      "${userns_args[@]}" \
      "${mount_args[@]}" \
      "${extra_arr[@]}" \
      "${env_args[@]}" \
      "$image" \
      bash -lc {{quote(CMD)}}

# Walk a process's ancestor chain and report how deeply zmx is nested
# in it. Motivating question: "is this session running under nested
# zmx?" (which is the precondition for issue #83's tent wedge under
# sc + zmx).
#
# Output:
#   1. `pstree -ps <pid>` so the full ancestor chain is visible.
#   2. A condensed table of zmx ancestors with PID / PPid / NSpgid /
#      NSsid / cmdline — so you can see which is the client (still in
#      caller's session) and which is the setsid()'d pty-leader.
#   3. A one-line summary: "zmx depth = N".
#
# The `.zmx-wrapped` name itself is a nix `wrapProgram` artifact, not
# a sign of double-wrapping (see issue #83 comment thread). Each
# `.zmx-wrapped` in the chain is a real fork of zmx, typically one
# client + one setsid'd pty-leader. Depth > 2 would be surprising.
#
# Read-only. Defaults to walking the recipe's own PPID (i.e. the
# shell that invoked `just`).
#
# Usage:
#   just zz-explore/zmx-depth           # walks $PPID
#   just zz-explore/zmx-depth PID=12345 # walks an arbitrary pid
zmx-depth PID='':
    #!/usr/bin/env bash
    set -uo pipefail
    pid="{{PID}}"
    if [[ -z "$pid" ]]; then
        pid=$PPID
    fi

    if [[ ! -d "/proc/$pid" ]]; then
        echo "FAIL: /proc/$pid does not exist." >&2
        exit 2
    fi

    echo "pid:  $pid"
    echo "time: $(date -Iseconds)"
    echo

    echo "=== ancestors (pstree -ps $pid) ==="
    pstree -ps "$pid" 2>/dev/null || echo "(pstree failed)"
    echo

    # Walk the parent chain ourselves so we can hit /proc fields that
    # pstree doesn't expose (NSsid, NSpgid, exact cmdline).
    declare -a zmx_pids=()
    cur="$pid"
    while [[ -n "$cur" && "$cur" != "0" && -d "/proc/$cur" ]]; do
        comm=$(cat "/proc/$cur/comm" 2>/dev/null || echo "?")
        if [[ "$comm" == ".zmx-wrapped" || "$comm" == "zmx" ]]; then
            zmx_pids+=("$cur")
        fi
        cur=$(awk '{print $4}' "/proc/$cur/stat" 2>/dev/null)
    done

    echo "=== zmx ancestors (${#zmx_pids[@]}) ==="
    if [[ ${#zmx_pids[@]} -eq 0 ]]; then
        echo "  (none — process is not running under zmx)"
    else
        printf '  %-8s %-8s %-8s %-8s %s\n' "PID" "PPid" "NSpgid" "NSsid" "CMDLINE"
        for zp in "${zmx_pids[@]}"; do
            ppid=$(awk '/^PPid:/ { print $2 }' "/proc/$zp/status" 2>/dev/null)
            pgid=$(awk '/^NSpgid:/ { print $2 }' "/proc/$zp/status" 2>/dev/null)
            sid=$(awk '/^NSsid:/ { print $2 }' "/proc/$zp/status" 2>/dev/null)
            cmd=$(tr '\0' ' ' < "/proc/$zp/cmdline" 2>/dev/null | cut -c1-60)
            printf '  %-8s %-8s %-8s %-8s %s\n' "$zp" "${ppid:-?}" "${pgid:-?}" "${sid:-?}" "$cmd"
        done
    fi
    echo

    echo "zmx depth = ${#zmx_pids[@]}"

# Forensic probe for a wedged process. Pairs with tent-hang-snapshot:
# given a hung PID, dump per-thread syscall + kernel stack + open-fd
# state. The point is to identify *what resource* a thread is blocked
# on without needing ptrace permissions (so the probe never disturbs
# the wedged process).
#
# Sources (all standard /proc, no strace needed):
#   - /proc/<pid>/task/<tid>/syscall  -> current syscall # + 6 args +
#                                       stack pointer + program counter.
#                                       Syscall # is the kernel's number;
#                                       cross-reference with `ausyscall
#                                       <n>` or the kernel headers.
#   - /proc/<pid>/task/<tid>/stack    -> kernel-side call stack. The
#                                       function names tell you what
#                                       subsystem is blocking (e.g.
#                                       pipe_read, ep_poll, futex_wait,
#                                       n_tty_read).
#   - /proc/<pid>/task/<tid>/wchan    -> single-symbol summary.
#   - /proc/<pid>/fd/                 -> resolves the fd numbers that
#                                       appear as syscall arg[0].
#
# Output is grouped by thread, with arg0-as-fd resolved against the
# fd table when plausible.
#
# Read-only. Safe to run on any wedged process; in particular, also
# useful on the inner zmx-wrapped, the inner shell, or podman in the
# #83 hang.
#
# Usage: just zz-explore/wedge-syscall-probe PID
wedge-syscall-probe PID:
    #!/usr/bin/env bash
    set -uo pipefail
    pid="{{PID}}"

    if [[ ! -d "/proc/$pid" ]]; then
        echo "FAIL: /proc/$pid does not exist." >&2
        exit 2
    fi

    echo "pid:  $pid"
    echo "time: $(date -Iseconds)"
    echo

    echo "=== /proc/$pid/cmdline ==="
    tr '\0' ' ' < "/proc/$pid/cmdline" 2>/dev/null; echo
    echo

    echo "=== /proc/$pid/fd (target table) ==="
    if [[ -d "/proc/$pid/fd" ]]; then
        printf '  %-4s %s\n' "FD" "TARGET"
        for fd_entry in "/proc/$pid/fd"/*; do
            [[ -L "$fd_entry" ]] || continue
            n=${fd_entry##*/}
            target=$(readlink "$fd_entry" 2>/dev/null || echo "?")
            printf '  %-4s %s\n' "$n" "$target"
        done
    else
        echo "  (no fd directory)"
    fi
    echo

    if [[ ! -d "/proc/$pid/task" ]]; then
        echo "(no task directory — single-threaded or unreadable)"
        exit 0
    fi

    for tdir in "/proc/$pid/task"/*; do
        [[ -d "$tdir" ]] || continue
        tid=${tdir##*/}

        tstate=$(awk '/^State:/ { print $2 }' "$tdir/status" 2>/dev/null)
        twchan=$(cat "$tdir/wchan" 2>/dev/null || echo "?")
        tcomm=$(cat "$tdir/comm" 2>/dev/null || echo "?")

        echo "=== tid=$tid state=$tstate wchan=$twchan comm=$tcomm ==="

        # Syscall file format: "<nr> <a0> <a1> <a2> <a3> <a4> <a5> <sp> <pc>"
        # or "running" if the thread isn't currently in a syscall.
        if [[ -r "$tdir/syscall" ]]; then
            sc=$(cat "$tdir/syscall" 2>/dev/null)
            echo "  syscall:  $sc"
            # Try to pull arg[0] in case it's an fd we already enumerated.
            read -r nr a0 _ <<< "$sc"
            if [[ "$nr" =~ ^[0-9]+$ && "$a0" =~ ^0x[0-9a-fA-F]+$ ]]; then
                a0_dec=$((a0))
                if [[ $a0_dec -ge 0 && $a0_dec -lt 4096 ]]; then
                    target=$(readlink "/proc/$pid/fd/$a0_dec" 2>/dev/null || echo "")
                    [[ -n "$target" ]] && echo "  arg0 as fd: $a0_dec -> $target"
                fi
            fi
        else
            echo "  syscall:  (unreadable)"
        fi

        if [[ -r "$tdir/stack" ]]; then
            echo "  kernel stack:"
            sed 's/^/    /' "$tdir/stack" 2>/dev/null | head -n 20
        else
            echo "  kernel stack: (unreadable — kernel.kptr_restrict?)"
        fi
        echo
    done

# Inspect unix-socket queue depths for a wedged process. /proc/net/unix
# does NOT carry RecvQ/SendQ — only `ss` does. This recipe enumerates
# the process's socket fds, resolves their inodes, then runs `ss -nxp`
# once and filters the output to rows matching those inodes. Cross-
# referenced with /proc/net/unix for connection state and peer.
#
# Use to distinguish "producer never wrote" (both queues 0) from
# "consumer never drained" (one queue non-zero), which is the next
# falsification step after the SIGWINCH test for issue #83.
#
# Read-only. Works on any pid, not just podman.
#
# Usage: just zz-explore/socket-queue-probe PID
socket-queue-probe PID:
    #!/usr/bin/env bash
    set -uo pipefail
    pid="{{PID}}"

    if [[ ! -d "/proc/$pid" ]]; then
        echo "FAIL: /proc/$pid does not exist." >&2
        exit 2
    fi

    echo "pid:  $pid"
    echo "time: $(date -Iseconds)"
    echo

    # Walk fds, collect socket-* targets with their inode numbers.
    declare -A sock_fd=()       # inode -> fd
    declare -a sock_inodes=()
    if [[ ! -d "/proc/$pid/fd" ]]; then
        echo "FAIL: /proc/$pid/fd unreadable." >&2
        exit 2
    fi
    for fd_entry in "/proc/$pid/fd"/*; do
        [[ -L "$fd_entry" ]] || continue
        n=${fd_entry##*/}
        target=$(readlink "$fd_entry" 2>/dev/null || echo "")
        case "$target" in
            socket:\[*\])
                ino=${target#socket:[}
                ino=${ino%]}
                sock_fd[$ino]=$n
                sock_inodes+=("$ino")
                ;;
        esac
    done

    echo "=== socket fds (${#sock_inodes[@]}) ==="
    if [[ ${#sock_inodes[@]} -eq 0 ]]; then
        echo "  (no sockets — nothing to probe)"
        exit 0
    fi
    printf '  %-4s %s\n' "FD" "INODE"
    for ino in "${sock_inodes[@]}"; do
        printf '  %-4s %s\n' "${sock_fd[$ino]}" "$ino"
    done
    echo

    # ss -nxp dumps unix sockets with RecvQ/SendQ + peer + holding pid.
    # Filter to our inodes. ss's output columns (header on first line):
    #   Netid State RecvQ SendQ LocalAddr:Port PeerAddr:Port Process
    # The inode appears at the end of LocalAddr ("ino" field) when
    # the socket has no bound path, or in the Process column (fd= /
    # ino=). To match reliably, grep against the literal inode number
    # — false positives are unlikely for the 7+ digit inodes ss uses.
    echo "=== ss -nxp filtered to these inodes ==="
    pattern=$(printf '%s|' "${sock_inodes[@]}" | sed 's/|$//')
    ss -nxp 2>/dev/null | awk -v pat="$pattern" 'NR==1 || $0 ~ pat'
    echo

    # Cross-reference with /proc/net/unix. Format:
    #   Num RefCount Protocol Flags Type State Inode [Path]
    # Type: 0001=STREAM 0002=DGRAM 0005=SEQPACKET
    # State: 01=unconnected 02=connecting 03=connected 04=disconnecting 05=listening
    echo "=== /proc/net/unix rows for these inodes ==="
    echo "  (cols: Num RefCount Proto Flags Type State Inode [Path])"
    echo "  (Type: 1=STREAM 2=DGRAM 5=SEQPACKET / State: 1=unconn 3=connected 5=listening)"
    pattern_pn=$(printf ' %s\\b|' "${sock_inodes[@]}" | sed 's/|$//')
    awk -v pat="$pattern_pn" 'NR==1 || $0 ~ pat' /proc/net/unix
    echo

    # TCP sockets too — podman opens these for its REST API.
    echo "=== ss -tnp filtered to pid $pid ==="
    ss -tnp 2>/dev/null | awk -v p="pid=$pid," 'NR==1 || $0 ~ p'

# Dump the journald stream conmon recorded for a container. Used to
# answer "what did the process inside actually write to its pty?"
# without ptrace.
#
# Podman's journald log driver tags each pty byte sent through conmon
# with CONTAINER_ID_FULL=<64-hex>, CONTAINER_ID=<12-hex>, and
# CONTAINER_NAME. We filter on CONTAINER_ID_FULL because it's the
# unambiguous one; the 12-hex CONTAINER_ID can collide across runs.
#
# Output is the raw MESSAGE field (no journald prefix noise) followed
# by a tail of the structured rows for debugging. The MESSAGE field
# can itself contain escape sequences (cursor queries, color codes);
# the recipe pipes it through cat -v so the bytes are visible in a
# normal terminal.
#
# Read-only.
#
# Usage: just zz-explore/tent-container-journal CID
#   CID can be the full 64-hex container id or any unique prefix.
#   Find it via `podman ps -aq` or from conmon's `-c <id>` argument
#   (visible in `pgrep -a conmon`).
tent-container-journal CID:
    #!/usr/bin/env bash
    set -uo pipefail
    cid="{{CID}}"

    if [[ -z "$cid" ]]; then
        echo "FAIL: CID is required." >&2
        exit 2
    fi

    # If a short id was passed, expand it. podman storage db has the
    # full ids as directory names under
    # ~/.local/share/containers/storage/overlay-containers/.
    full=""
    if [[ ${#cid} -ge 60 ]]; then
        full=$cid
    else
        for dir in ~/.local/share/containers/storage/overlay-containers/"$cid"*; do
            [[ -d "$dir" ]] || continue
            full=$(basename "$dir")
            break
        done
        if [[ -z "$full" ]]; then
            echo "FAIL: no container directory found matching prefix '$cid'." >&2
            exit 2
        fi
    fi

    short=${full:0:12}
    echo "cid:    $full"
    echo "short:  $short"
    echo "time:   $(date -Iseconds)"
    echo

    echo "=== MESSAGE field — system journal (raw bytes via cat -v) ==="
    journalctl --no-pager -o cat \
        CONTAINER_ID_FULL="$full" 2>/dev/null | cat -v || \
        echo "(no rows in system journal)"
    echo
    echo
    echo "=== MESSAGE field — user journal (fallback) ==="
    journalctl --user --no-pager -o cat \
        CONTAINER_ID_FULL="$full" 2>/dev/null | cat -v || \
        echo "(no rows in user journal)"
    echo
    echo
    echo "=== last 20 structured rows from system journal (with metadata) ==="
    journalctl --no-pager -n 20 \
        -o short \
        CONTAINER_ID_FULL="$full" 2>/dev/null \
        | sed 's/^/  /' || echo "  (no rows)"
    echo
    echo "=== any system-journal rows mentioning the short cid ==="
    journalctl --no-pager -n 20 -g "$short" 2>/dev/null \
        | sed 's/^/  /' | head -n 60 || echo "  (no rows)"

# Snapshot /proc/<pid>/io for one or more PIDs. Used to detect whether
# a process has been reading or writing bytes by comparing two
# snapshots (call twice with the same PIDs, take a delta).
#
# Each line of /proc/<pid>/io has the byte counters:
#   rchar, wchar          — bytes read/written via read()/write() syscalls
#                           (includes those served from the page cache)
#   read_bytes, write_bytes — bytes that actually touched a block device
#   syscr, syscw          — count of read/write syscalls
#
# Use rchar / wchar / syscr / syscw to spot tty/pipe activity (block-
# device counters don't move for pty I/O). If a process is supposed
# to be forwarding bytes but rchar and syscr both stay constant across
# two snapshots, it isn't reading anything from anywhere.
#
# Read-only. Accepts space-separated PIDs.
#
# Usage:
#   just zz-explore/io-probe "3001701 3001716 3001721 2989810 2989812"
io-probe PIDS:
    #!/usr/bin/env bash
    set -uo pipefail
    pids="{{PIDS}}"
    if [[ -z "$pids" ]]; then
        echo "FAIL: at least one PID required." >&2
        exit 2
    fi

    echo "time: $(date -Iseconds)"
    echo
    printf '  %-8s %-12s %-12s %-12s %-12s %s\n' "PID" "RCHAR" "WCHAR" "SYSCR" "SYSCW" "COMM"
    for p in $pids; do
        if [[ ! -r "/proc/$p/io" ]]; then
            printf '  %-8s %s\n' "$p" "(unreadable or gone)"
            continue
        fi
        comm=$(cat "/proc/$p/comm" 2>/dev/null || echo "?")
        rchar=$(awk '/^rchar:/ { print $2 }' "/proc/$p/io" 2>/dev/null)
        wchar=$(awk '/^wchar:/ { print $2 }' "/proc/$p/io" 2>/dev/null)
        syscr=$(awk '/^syscr:/ { print $2 }' "/proc/$p/io" 2>/dev/null)
        syscw=$(awk '/^syscw:/ { print $2 }' "/proc/$p/io" 2>/dev/null)
        printf '  %-8s %-12s %-12s %-12s %-12s %s\n' \
            "$p" "${rchar:-?}" "${wchar:-?}" "${syscr:-?}" "${syscw:-?}" "$comm"
    done

# Run a specific claude-code binary inside the clown-tent image to
# isolate whether the issue #83 TUI-init wedge is a regression in a
# particular claude-code version. Bypasses clown's plugin pipeline
# entirely — vanilla claude, no plugin-dir, no agents, no MCP — so
# any wedge we observe is purely a function of claude's interaction
# with the libvterm-emulated terminal exposed by zmx-leader.
#
# IMPORTANT: run this from inside the wedge-reproducing sc+zmx
# session for the result to be diagnostic. From a non-zmx terminal
# claude will work regardless.
#
# CLAUDE_BIN must be an absolute path inside /nix/store (since the
# tent only bind-mounts /nix/store, not /home or arbitrary paths).
# Discover candidates with:
#   ls -d /nix/store/*claude-code*/bin/claude
#
# IMAGE defaults to the tent image whose tag matches the worktree's
# version.txt (mirrors what `clown --tent` would launch). Override
# to test against a differently-tagged tent.
#
# Usage:
#   just zz-explore/tent-claude-version CLAUDE_BIN=/nix/store/.../claude-code-2.1.111/bin/claude
#   just zz-explore/tent-claude-version CLAUDE_BIN=/nix/store/.../bin/claude IMAGE=clown-tent:0.3.2
tent-claude-version CLAUDE_BIN IMAGE='':
    #!/usr/bin/env bash
    set -uo pipefail

    claude_bin="{{CLAUDE_BIN}}"
    image="{{IMAGE}}"

    if [[ -z "$image" ]]; then
        root=$(git rev-parse --show-toplevel)
        ver=$(tr -d '[:space:]' < "$root/version.txt")
        image="clown-tent:$ver"
    fi

    if [[ ! -x "$claude_bin" ]]; then
        echo "FAIL: '$claude_bin' is not an executable file." >&2
        echo "      Candidates on this host:" >&2
        ls -d /nix/store/*claude-code*/bin/claude 2>/dev/null \
            | sed 's/^/        /' >&2 \
            || echo "        (none — try 'nix run nixpkgs#claude-code -- --version' to fetch one)" >&2
        exit 2
    fi

    if ! /usr/bin/podman image exists "$image"; then
        echo "FAIL: image '$image' not loaded. Run 'just build' to" >&2
        echo "      produce the tent tarball, then 'podman load -i" >&2
        echo "      \$(nix path-info .#tent-image)' to load it." >&2
        exit 2
    fi

    echo "image:  $image"
    echo "claude: $claude_bin"
    echo
    echo ">> launching vanilla claude inside tent (Ctrl-C to exit)"
    echo "   no plugin-dir, no --agents, no --append-system-prompt-file"
    echo

    exec /usr/bin/podman run --rm -i -t --userns=keep-id \
        --volume /nix/store:/nix/store:ro \
        "$image" \
        "$claude_bin"

# Probe whether the ~/.claude config paths are writable from inside
# the clown-tent image under the same volume mounts + userns mapping
# that `clown --tent` uses. Falsifies / confirms the theory (matching
# upstream claude-code issues #29162 and #56893) that issue #83's
# wedge is claude silently looping on EPERM/ENOENT during config
# writes.
#
# Drops `-t` so the recipe can be run non-interactively via `just`.
# Doesn't run claude — just exercises the same FS surface claude
# would touch on startup.
#
# Usage: just zz-explore/tent-claude-writeability
tent-claude-writeability:
    #!/usr/bin/env bash
    set -uo pipefail
    /usr/bin/podman run --rm -i --userns=keep-id \
      --volume /nix/store:/nix/store:ro \
      --volume /home/sasha/.claude:/home/sasha/.claude \
      --volume /home/sasha/.claude.json:/home/sasha/.claude.json \
      clown-tent:0.3.2 \
      sh -c '
        echo "id:      $(id)"
        echo "uid_map: $(cat /proc/self/uid_map)"
        echo
        echo "-- stat ~/.claude --"
        ls -ld /home/sasha/.claude
        echo "-- stat ~/.claude.json --"
        ls -l /home/sasha/.claude.json
        echo
        echo "-- touch ~/.claude/write-test --"
        touch /home/sasha/.claude/write-test 2>&1 \
          && { echo OK; rm -f /home/sasha/.claude/write-test; } \
          || echo FAIL
        echo
        echo "-- touch ~/.claude/debug/write-test --"
        mkdir -p /home/sasha/.claude/debug 2>&1
        touch /home/sasha/.claude/debug/write-test 2>&1 \
          && { echo OK; rm -f /home/sasha/.claude/debug/write-test; } \
          || echo FAIL
        echo
        echo "-- append+restore to ~/.claude.json --"
        cp /home/sasha/.claude.json /tmp/orig.json
        printf "\n" >> /home/sasha/.claude.json 2>&1 \
          && echo OK \
          || echo FAIL
        cp /tmp/orig.json /home/sasha/.claude.json 2>/dev/null
      '

# Run claude --debug inside the clown-tent under the same mounts /
# userns mapping as `clown --tent`, with a hard timeout, then dump
# everything it logged (both to stdout/stderr and to its own
# ~/.claude/debug/ file). The strace-level investigation can't see
# what claude is doing at the JS level, but --debug should — per
# upstream issue #29162 the same hang signature was diagnosed only
# by reading the debug log after the wedge.
#
# This recipe drops `-t` (so podman doesn't need a tty), pipes
# stdout/stderr to a file, gives the container `TIMEOUT_S` seconds
# to wedge, then kills it and reports.
#
# DURATION defaults to 10 (seconds). Pass DURATION=5 for a quick
# probe or DURATION=30 if you need claude to get further along
# before we yank it.
#
# Read-only with respect to host state except for the captured
# log files (under .tmp/).
#
# Usage:
#   just zz-explore/tent-claude-with-debug
#   just zz-explore/tent-claude-with-debug DURATION=20
tent-claude-with-debug DURATION='10':
    #!/usr/bin/env bash
    set -uo pipefail
    secs="{{DURATION}}"

    out_dir=".tmp/tent-claude-with-debug-$(date +%s)"
    mkdir -p "$out_dir"
    stdio_log="$out_dir/stdio.log"

    # Snapshot the debug dir BEFORE the run so we can diff the
    # listings and identify whatever new file claude creates.
    before_list="$out_dir/before.list"
    after_list="$out_dir/after.list"
    ls -la /home/sasha/.claude/debug/ 2>/dev/null > "$before_list" || true

    echo "out_dir:     $out_dir"
    echo "stdio_log:   $stdio_log"
    echo "duration:    ${secs}s"
    echo
    echo ">> launching claude --debug inside tent (timeout ${secs}s)"

    # `timeout --signal=KILL` because podman+conmon swallows SIGTERM
    # and lingers. KILL kills the podman client; conmon and the
    # container will then clean up via their normal --rm flow.
    timeout --signal=KILL "${secs}" /usr/bin/podman run --rm -i \
        --userns=keep-id \
        --env HOME=/home/sasha \
        --env USER=sasha \
        --volume /nix/store:/nix/store:ro \
        --volume /home/sasha/.claude:/home/sasha/.claude \
        --volume /home/sasha/.claude.json:/home/sasha/.claude.json \
        clown-tent:0.3.2 \
        sh -c 'stty rows 39 cols 141 2>/dev/null; exec /nix/store/dii6cpbdqzjcjqcy18x6n56cql0fmdg9-claude-code-2.1.111/bin/claude --debug' \
      > "$stdio_log" 2>&1 || true

    echo ">> exited (or was killed by timeout)"
    echo

    # Give conmon a moment to flush.
    sleep 1
    ls -la /home/sasha/.claude/debug/ 2>/dev/null > "$after_list" || true

    echo "=== stdio capture (head 200 lines) ==="
    head -n 200 "$stdio_log" 2>/dev/null | sed 's/^/  /' \
        || echo "  (empty)"
    if [[ $(wc -l < "$stdio_log" 2>/dev/null || echo 0) -gt 200 ]]; then
        echo "  ... (truncated; full file at $stdio_log)"
    fi
    echo

    echo "=== new files in ~/.claude/debug/ (diff before/after) ==="
    diff "$before_list" "$after_list" \
        | grep -E '^>' \
        | sed 's/^> /  /' \
        || echo "  (no new files)"
    echo

    # If claude created a fresh debug log, tail it. Symlink target
    # is the freshest session log; per #29162 this is where the
    # actual EPERM/ENOENT errors live, hidden from stdout.
    if [[ -L /home/sasha/.claude/debug/latest ]]; then
        target=$(readlink /home/sasha/.claude/debug/latest 2>/dev/null)
        echo "=== ~/.claude/debug/latest -> $target ==="
        if [[ -r "$target" ]]; then
            wc -l "$target" 2>/dev/null | sed 's/^/  /'
            echo "  --- head ---"
            head -n 100 "$target" 2>/dev/null | sed 's/^/    /'
            echo "  --- tail ---"
            tail -n 100 "$target" 2>/dev/null | sed 's/^/    /'
        else
            echo "  (target not readable: $target)"
        fi
    else
        echo "=== ~/.claude/debug/latest ==="
        echo "  (no symlink — claude didn't write a session log)"
    fi

# Run claude --debug interactively (with `-t`) inside the tent under
# the same mounts / env mapping as `clown --tent`. Unlike
# `tent-claude-with-debug` (which drops -t so it can run through
# `just` without a terminal), this recipe execs podman directly so
# you get a real pty and claude initializes in TUI mode. Designed
# for catching the issue #83 wedge: launch this, watch the TUI
# wedge, hit Ctrl-C, then read the debug log that claude wrote.
#
# MUST be invoked from a real interactive shell — not via the
# just-us-agents MCP tool — because it needs a tty for podman -t.
#
# The debug log path is printed before launch. After you Ctrl-C
# out of the wedge, `cat <path>` to see what claude was doing
# JS-side.
#
# Parameters:
#   CLAUDE_BIN  Path to the claude binary in /nix/store. Default is
#               claude-code 2.1.111 (the version that launches cleanly
#               with the empty arg set). Pass a 2.1.143 path to test
#               the version-regression hypothesis. Discover candidates:
#                 ls -d /nix/store/*claude-code*/bin/claude
#   EXTRA_ARGS  Additional args appended to claude's invocation. Use
#               to incrementally re-add the clown-tent injection
#               (--plugin-dir, --agents, --append-system-prompt-file,
#               --session-id) and find which one triggers the wedge.
#               Bash word-split as-is — quote externally.
#
# Usage (positional — `CLAUDE_BIN=…` style does NOT work in just,
# despite the docstring convention elsewhere in this file):
#   just zz-explore/tent-claude-with-debug-tty
#   just zz-explore/tent-claude-with-debug-tty \
#     /nix/store/5djd2jhp5kxpirahbi1w7xq85cyh3d08-claude-code-2.1.143/bin/claude
#   just zz-explore/tent-claude-with-debug-tty \
#     /nix/store/dii6cpbdqzjcjqcy18x6n56cql0fmdg9-claude-code-2.1.111/bin/claude \
#     '--plugin-dir /nix/store/m4yalh23h3dfxg95mw7vrymlx6w7mi60-eng-plugin/share/purse-first/eng'
tent-claude-with-debug-tty CLAUDE_BIN='/nix/store/dii6cpbdqzjcjqcy18x6n56cql0fmdg9-claude-code-2.1.111/bin/claude' EXTRA_ARGS='':
    #!/usr/bin/env bash
    set -uo pipefail

    claude_bin="{{CLAUDE_BIN}}"
    extra_args="{{EXTRA_ARGS}}"

    if [[ ! -x "$claude_bin" ]]; then
        echo "FAIL: '$claude_bin' is not an executable file." >&2
        echo "      Candidates on this host:" >&2
        ls -d /nix/store/*claude-code*/bin/claude 2>/dev/null \
            | sed 's/^/        /' >&2 \
            || echo "        (none found in /nix/store)" >&2
        exit 2
    fi

    echo "claude:     $claude_bin"
    echo "extra args: ${extra_args:-(none)}"
    echo "debug log:  ~/.claude/debug/latest after run"
    echo "  current target: $(readlink /home/sasha/.claude/debug/latest 2>/dev/null || echo '<none>')"
    echo

    # Build the inner sh command: stty for winsize, then exec claude
    # with --debug + EXTRA_ARGS. shell-quote $claude_bin so paths
    # with shell-meaningful chars survive; trust EXTRA_ARGS verbatim
    # so the caller controls word-splitting/quoting.
    inner_cmd="stty rows 39 cols 141 2>/dev/null; exec \"$claude_bin\" --debug $extra_args"

    exec /usr/bin/podman run --rm -i -t \
        --userns=keep-id \
        --env HOME=/home/sasha \
        --env USER=sasha \
        --env TERM \
        --volume /nix/store:/nix/store:ro \
        --volume /home/sasha/.claude:/home/sasha/.claude \
        --volume /home/sasha/.claude.json:/home/sasha/.claude.json \
        clown-tent:0.3.2 \
        sh -c "$inner_cmd"
