#!/usr/bin/env python3
"""List resumable coding-agent sessions for shell completion.

Supports both Claude Code (JSONL transcripts) and Codex (SQLite state DB).
Use --provider codex to list Codex sessions; defaults to Claude.
"""

import json
import sqlite3
import sys
from pathlib import Path

TAIL_BYTES = 4096


def extract_session_name(transcript: Path) -> str:
    """Read the last TAIL_BYTES of a .jsonl transcript for a session name.

    Claude Code writes custom-title and agent-name entries near the end
    of the transcript. Prefer custom-title if both exist.
    """
    try:
        size = transcript.stat().st_size
    except OSError:
        return ""
    if size == 0:
        return ""

    name = ""
    try:
        with transcript.open("rb") as fh:
            fh.seek(max(0, size - TAIL_BYTES))
            tail = fh.read().decode("utf-8", errors="replace")
    except OSError:
        return ""

    for line in tail.splitlines():
        try:
            entry = json.loads(line)
        except (json.JSONDecodeError, ValueError):
            continue
        entry_type = entry.get("type", "")
        if entry_type == "agent-name" and not name:
            name = entry.get("agentName", "")
        elif entry_type == "custom-title":
            name = entry.get("customTitle", "")
    return name


def list_claude_sessions():
    projects_dir = Path.home() / ".claude" / "projects"
    if not projects_dir.is_dir():
        return

    for project in projects_dir.iterdir():
        if not project.is_dir():
            continue
        for f in project.iterdir():
            if f.suffix != ".jsonl" or not f.is_file():
                continue
            sid = f.stem
            name = extract_session_name(f)
            if name:
                print(f"{name}\t{sid}")
            else:
                print(sid)


def list_codex_sessions():
    db_path = Path.home() / ".codex" / "state_5.sqlite"
    if not db_path.is_file():
        return

    try:
        conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    except sqlite3.Error:
        return

    query = """
        select id, title
        from threads
        where archived = 0
        order by updated_at desc
    """

    try:
        with conn:
            for session_id, title in conn.execute(query):
                if title:
                    print(f"{title}\t{session_id}")
                else:
                    print(session_id)
    except sqlite3.Error:
        return


def main():
    provider = "claude"
    args = sys.argv[1:]
    i = 0
    while i < len(args):
        if args[i] == "--provider" and i + 1 < len(args):
            provider = args[i + 1]
            i += 2
        elif args[i].startswith("--provider="):
            provider = args[i].split("=", 1)[1]
            i += 1
        else:
            i += 1

    if provider == "codex":
        list_codex_sessions()
    else:
        list_claude_sessions()


if __name__ == "__main__":
    main()
